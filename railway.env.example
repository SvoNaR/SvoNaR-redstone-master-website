# Переменные окружения для Railway (Service → Variables).
# Скопируйте значения в панель Railway; файл в Git не коммитьте с реальными секретами.

SPRING_PROFILES_ACTIVE=production,railway

APP_BASE_URL=https://redstone-master.up.railway.app
APP_ADMIN_PASSWORD=замените_на_сильный_пароль
APP_MAIL_FROM=redstone.master.dev@gmail.com

# Railway блокирует исходящий SMTP (порты 25/465/587) — в Network Flow Logs это ICMP_CSUM.
# Используйте SendGrid API (HTTPS), а не Gmail SMTP:
# 1. https://app.sendgrid.com → Settings → API Keys → Create API Key (Mail Send)
# 2. Settings → Sender Authentication → Verify a Single Sender → redstone.master.dev@gmail.com
# 3. Вставьте ключ ниже (начинается с SG.)
SENDGRID_API_KEY=

# Локальная разработка (SMTP Gmail). На Railway не нужен:
# SPRING_MAIL_PASSWORD=
