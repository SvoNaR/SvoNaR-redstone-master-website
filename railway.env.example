# Переменные окружения для Railway (Service → Variables).
# Скопируйте значения в панель Railway; файл в Git не коммитьте с реальными секретами.

SPRING_PROFILES_ACTIVE=production,railway

APP_BASE_URL=https://redstone-master.up.railway.app
APP_ADMIN_PASSWORD=замените_на_сильный_пароль

# Пароль приложения Gmail (не пароль от аккаунта)
SPRING_MAIL_PASSWORD=

# Опционально, если не используете профиль railway:
# SPRING_DATASOURCE_URL=jdbc:h2:file:/data/redstone-web;DB_CLOSE_DELAY=-1
# APP_AVATARS_USER_DIR=/data/avatars/users
# APP_MODERATION_WORKSPACE_DIR=/data/moderation/workspaces
# APP_MODERATION_JAR_OUTPUT_DIR=/data/moderation/jars
